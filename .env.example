# ==============================================================================
# Real Estate CRM — Environment Variables Template
# ==============================================================================
# Copy this to .env and fill in values specific to your environment.
# For development, use .env.dev instead.
# ==============================================================================

# ─── Database ──────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://crm_user:CHANGE_ME_TO_A_STRONG_PASSWORD@localhost:5432/real_estate_crm

# ─── AuthMe IAM ───────────────────────────────────────────────────────
# Base URL of the AuthMe server (no trailing slash)
AUTHME_URL=http://localhost:3001

# Realm name configured in AuthMe (see docs/authme-setup.md)
# Format: real-estate-{environment}
# Examples: real-estate-dev, real-estate-qa, real-estate-uat, real-estate
AUTHME_REALM=real-estate

# Public issuer URL — overrides AUTHME_URL for JWT issuer validation.
# Set this when the internal AUTHME_URL differs from the public URL in JWT tokens.
# Example: https://dev-auth.realstate-crm.homes
# AUTHME_ISSUER_URL=

# Backend client ID registered in AuthMe
AUTHME_CLIENT_ID=crm-backend

# Backend client secret
# ⚠️  DEV ONLY: Use proper secret management in production (e.g., AWS Secrets Manager, HashiCorp Vault)
# Get from: AuthMe Console → Clients → crm-backend → Credentials → Client Secret
# DO NOT commit real secrets to version control
AUTHME_CLIENT_SECRET=dev-secret-change-in-production

# ─── CORS Origins ─────────────────────────────────────────────────────
# Portal URLs used for CORS allowlisting (must match exactly, including port and protocol)
# Admin portal URL (e.g., http://localhost:5173 for dev, https://admin.example.com for prod)
ADMIN_PORTAL_URL=http://localhost:5173

# Agent portal URL (e.g., http://localhost:5174 for dev, https://agent.example.com for prod)
AGENT_PORTAL_URL=http://localhost:5174

# ─── Server ───────────────────────────────────────────────────────────
# Node environment: development, staging, or production
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# ─── File Uploads ─────────────────────────────────────────────────────
# Directory where uploaded images and documents are stored
# Use absolute path in production
UPLOAD_DIR=./uploads

# ─── Redis (used by Bull email queue) ─────────────────────────────────
# Redis connection for background job processing
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank if Redis has no password
REDIS_PASSWORD=

# ─── SMTP (email delivery) ────────────────────────────────────────────
# Email server configuration
# For development, use MailHog: https://github.com/mailhog/MailHog
# For production, use AWS SES, SendGrid, or similar
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@realestate-crm.com

# ─── Rate Limiting ─────────────────────────────────────────────────────
# Request rate limiting configuration (in milliseconds)
# TTL = time window, LIMIT = max requests within that window
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Database Pool ─────────────────────────────────────────────────────
# Connection pool settings for database
DATABASE_POOL_SIZE=10
DATABASE_IDLE_TIMEOUT=30000

# ─── Docker Compose (production deployment) ───────────────────────────
# PostgreSQL Docker credentials (must match DATABASE_URL)
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=real_estate_crm

# Port mapping for services
HTTP_PORT=80
HTTPS_PORT=443
