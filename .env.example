# ─── Database ──────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://crm_user:CHANGE_ME_TO_A_STRONG_PASSWORD@localhost:5432/real_estate_crm

# ─── Authme IAM ───────────────────────────────────────────────────────
# Base URL of the Authme server (no trailing slash)
AUTHME_URL=http://localhost:3001
# Realm name configured in Authme (see docs/authme-setup.md)
AUTHME_REALM=real-estate
# Backend client ID registered in Authme
AUTHME_CLIENT_ID=crm-backend
# Backend client secret (leave empty for public clients)
AUTHME_CLIENT_SECRET=

# ─── CORS Origins ─────────────────────────────────────────────────────
# Portal URLs used for CORS allowlisting (must match exactly, including port)
ADMIN_PORTAL_URL=http://localhost:5173
AGENT_PORTAL_URL=http://localhost:5174

# ─── Server ───────────────────────────────────────────────────────────
PORT=3000
# Set to "production" in deployed environments
NODE_ENV=development

# ─── File Uploads ─────────────────────────────────────────────────────
# Directory where uploaded images and documents are stored
UPLOAD_DIR=./uploads

# ─── Docker Compose (production only) ─────────────────────────────────
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=real_estate_crm
HTTP_PORT=80
HTTPS_PORT=443
