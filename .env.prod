# ==============================================================================
# Real Estate CRM — Production Environment Variables
# ==============================================================================
# Used by docker-compose on the production server
# ==============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://crm_user:real-estate-prod-password-secure-change-me@host.docker.internal:5435/real_estate_crm_prod

# --- Authme IAM --------------------------------------------------------------
AUTHME_URL=http://crm-prod-authme:3001
AUTHME_REALM=real-estate
AUTHME_CLIENT_ID=crm-backend
AUTHME_ISSUER_URL=https://auth.realstate-crm.homes
AUTHME_CLIENT_SECRET=change-me-to-actual-secret-from-authme

# --- CORS Origins ------------------------------------------------------------
ADMIN_PORTAL_URL=https://admin.realstate-crm.homes
AGENT_PORTAL_URL=https://agent.realstate-crm.homes

# --- Server ------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# --- File Uploads ------------------------------------------------------------
UPLOAD_DIR=/app/uploads

# --- Redis (Bull email queue) ------------------------------------------------
REDIS_HOST=crm-prod-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- SMTP (email delivery) ---------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@realestate-crm.com

# --- Rate Limiting -----------------------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# --- Database Pool -----------------------------------------------------------
DATABASE_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT=30000

# --- Docker Compose Config ---------------------------------------------------
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=real-estate-prod-password-secure-change-me
POSTGRES_DB=real_estate_crm_prod

HTTP_PORT=80
HTTPS_PORT=443
