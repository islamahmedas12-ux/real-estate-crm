# ==============================================================================
# Real Estate CRM — Dev Environment Variables
# ==============================================================================
# Copy this file to .env before running docker-compose.dev-full.yml
#   cp .env.dev .env
# ==============================================================================

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/real_estate_crm

# ─── Authme IAM ───────────────────────────────────────────────────────
# AuthMe Base URL (use http://authme:3001 inside Docker, http://localhost:3001 from host)
AUTHME_URL=http://authme:3001

# Realm name configured in AuthMe
AUTHME_REALM=real-estate-dev

# Backend client ID registered in AuthMe
AUTHME_CLIENT_ID=crm-backend

# Backend client secret (from AuthMe console → Clients → crm-backend → Credentials)
# Get the secret by running: ./scripts/setup-authme-dev.sh
# Or manually from: http://localhost:3001/console
# Navigate to: Clients → crm-backend → Credentials tab → Copy Client Secret
AUTHME_CLIENT_SECRET=change-me-to-actual-secret-from-authme

# ─── CORS Origins ─────────────────────────────────────────────────────
# Portal URLs used for CORS allowlisting (must match exactly, including port)
ADMIN_PORTAL_URL=http://localhost:5173
AGENT_PORTAL_URL=http://localhost:5174

# ─── Server ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── File Uploads ─────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── Redis (used by Bull email queue) ─────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Leave blank if Redis has no password
REDIS_PASSWORD=

# ─── SMTP (email delivery) ────────────────────────────────────────────
# For dev, these can be left empty or set to a local mailhog instance
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@realestate-crm.dev

# ─── Rate Limiting ─────────────────────────────────────────────────────
# TTL in milliseconds and max requests per TTL window
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Database Pool ─────────────────────────────────────────────────────
DATABASE_POOL_SIZE=10
DATABASE_IDLE_TIMEOUT=30000

# ─── Docker Compose Config ───────────────────────────────────────────
# PostgreSQL Docker credentials (must match DATABASE_URL above)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=real_estate_crm
