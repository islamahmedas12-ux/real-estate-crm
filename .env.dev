# ==============================================================================
# Real Estate CRM — Dev Environment Variables
# ==============================================================================
# Used by docker-compose.dev-server.yml on the dev server
# ==============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://crm_user:real-estate-dev-password-123@host.docker.internal:5432/real_estate_crm_dev

# --- Authme IAM --------------------------------------------------------------
AUTHME_URL=http://crm-dev-authme:3001
AUTHME_REALM=real-estate-dev
AUTHME_CLIENT_ID=crm-backend
AUTHME_ISSUER_URL=https://dev-auth.realstate-crm.homes
AUTHME_CLIENT_SECRET=3d556405eb8c5aed1910239a59d548c195dc7a698f0aaa7b11e84a970eca2d7f

# --- CORS Origins ------------------------------------------------------------
ADMIN_PORTAL_URL=https://dev-admin.realstate-crm.homes
AGENT_PORTAL_URL=https://dev-agent.realstate-crm.homes

# --- Server ------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# --- File Uploads ------------------------------------------------------------
UPLOAD_DIR=/app/uploads

# --- Redis (Bull email queue) ------------------------------------------------
REDIS_HOST=crm-dev-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- SMTP (email delivery) ---------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@realestate-crm.dev

# --- Rate Limiting -----------------------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --- Database Pool -----------------------------------------------------------
DATABASE_POOL_SIZE=10
DATABASE_IDLE_TIMEOUT=30000

# --- Docker Compose Config ---------------------------------------------------
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=real-estate-dev-password-123
POSTGRES_DB=real_estate_crm_dev
