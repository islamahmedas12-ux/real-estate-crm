# ==============================================================================
# Real Estate CRM — UAT Environment Variables
# ==============================================================================
# Used by docker-compose on the UAT server
# ==============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://crm_user:real-estate-uat-password-123@host.docker.internal:5434/real_estate_crm_uat

# --- Authme IAM --------------------------------------------------------------
AUTHME_URL=http://crm-uat-authme:3001
AUTHME_REALM=real-estate-uat
AUTHME_CLIENT_ID=crm-backend
AUTHME_ISSUER_URL=https://uat-auth.realstate-crm.homes
AUTHME_CLIENT_SECRET=change-me-to-actual-secret-from-authme

# --- CORS Origins ------------------------------------------------------------
ADMIN_PORTAL_URL=https://uat-admin.realstate-crm.homes
AGENT_PORTAL_URL=https://uat-agent.realstate-crm.homes

# --- Server ------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# --- File Uploads ------------------------------------------------------------
UPLOAD_DIR=/app/uploads

# --- Redis (Bull email queue) ------------------------------------------------
REDIS_HOST=crm-uat-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- SMTP (email delivery) ---------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@realestate-crm.com

# --- Rate Limiting -----------------------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --- Database Pool -----------------------------------------------------------
DATABASE_POOL_SIZE=10
DATABASE_IDLE_TIMEOUT=30000

# --- Docker Compose Config ---------------------------------------------------
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=real-estate-uat-password-123
POSTGRES_DB=real_estate_crm_uat
